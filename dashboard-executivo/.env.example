# =============================================================================
# Dashboard Executivo — Greenlife Academias
# API: PACTO (apigw.pactosolucoes.com.br)
# Copie este arquivo para .env e preencha os valores reais
# NUNCA versione o arquivo .env
# =============================================================================

# Bearer Token de autenticação (obtido junto à PACTO ou via endpoint de login)
PACTO_TOKEN=

# ID da empresa Greenlife no sistema PACTO (integer, vai no header empresaId)
PACTO_EMPRESA_ID=

# URL base da API (não alterar)
PACTO_BASE_URL=https://apigw.pactosolucoes.com.br

# Timeout em segundos por requisição
REQUEST_TIMEOUT=30

# Tentativas automáticas em falhas temporárias (429, 500, 502, 503)
MAX_RETRIES=3

# Pausa em segundos entre tentativas
RETRY_DELAY=5
